    {
        taksiCena = 0.70 + razstoyanie * 0.90;
    }

    if (razstoyanie >= 20)
    {
        avtobusCena = razstoyanie * 0.09;
    }
    else
    {
        avtobusCena = -1;
    }

    if (razstoyanie >= 100)
    {
        vlakCena = razstoyanie * 0.06;
    }
    else
    {
        vlakCena = -1;
    }

    minimalnaCena = taksiCena;

