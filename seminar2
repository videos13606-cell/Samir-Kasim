    {
        printf("Putuvayte s vlak za: ");
    }
    else if (minimalnaCena == avtobusCena && avtobusCena != -1)
    {
        printf("Putuvayte s avtobus za: ");
    }
    else
    {
        printf("Putuvayte s taksi za: ");
    }

    printf("%.1f", minimalnaCena);

    return 0;
}
int zadacha8()
{
 double V, debet1, debet2, N;
    double obshtoVoda, procentZapulnen, truba1Procent, truba2Procent;

    printf("Vuvedete obem na baseyna (kubichni metri): ");
    scanf("%lf", &V);
    printf("Vuvedete debet na purvata truba (litri v chas): ");
    scanf("%lf", &debet1);
    printf("Vuvedete debet na vtorata truba (litri v chas): ");
    scanf("%lf", &debet2);
    printf("Vuvedete chasove, koito rabotnikut e otsastval: ");
    scanf("%lf", &N);

    obshtoVoda = (debet1 + debet2) * N;

    if (obshtoVoda >= V * 1000)
    {
        printf("Baseynut se e preplnil s %.2f litra.\n", obshtoVoda - V * 1000);
    }
    else
    {
        procentZapulnen = (obshtoVoda / (V * 1000)) * 100;
        truba1Procent = (debet1 * N / obshtoVoda) * 100;
        truba2Procent = (debet2 * N / obshtoVoda) * 100;
        printf("Baseynut e zapulnen na %.2f%%.\n", procentZapulnen);
        printf("Pyrvata truba: %.2f%%.\n", truba1Procent);
        printf("Vtorata truba: %.2f%%.\n", truba2Procent);
    }
    return 0;
}
