int zadacha12()
{
    int n;
    printf("Vuvedete n: ");
    scanf("%d", &n);

    for(int red = 0; red < n - 2; red++) {
        for(int i = 0; i < n - 1 - red; i++) printf("*");
        printf("\\");
        for(int i = 0; i < red; i++) printf(" ");
        printf("/");
        for(int i = 0; i < n - 1 - red; i++) printf("*");
        printf("\n");

        if(red < n - 3) {
            for(int i = 0; i < n - 1 - red; i++) printf("-");
            printf("\\");
            for(int i = 0; i < red; i++) printf(" ");
            printf("/");
            for(int i = 0; i < n - 1 - red; i++) printf("-");
            printf("\n");
        }
    }

    for(int i = 0; i < n - 1; i++) printf(" ");
    printf("@\n");

    for(int red = n - 3; red >= 0; red--) {
        for(int i = 0; i < n - 1 - red; i++) printf("*");
        printf("/");
        for(int i = 0; i < red; i++) printf(" ");
        printf("\\");
        for(int i = 0; i < n - 1 - red; i++) printf("*");
        printf("\n");

        if(red > 0) {
            for(int i = 0; i < n - 1 - red; i++) printf("-");
            printf("/");
            for(int i = 0; i < red; i++) printf(" ");
            printf("\\");
            for(int i = 0; i < n - 1 - red; i++) printf("-");
            printf("\n");
        }
    }

    return 0;
}
