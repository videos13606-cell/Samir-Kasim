void zadacha4()
{
    char symbol;
    printf("Vuvedete znak za triugulnika: ");
    scanf(" %c", &symbol);
    printf("\nPrav triugulnik:\n\n");
    int spaces = 8;
    for(int i = 0; i < 5; i++)
    {
        for(int j = 0; j < spaces; j++)
        {
            printf(" ");
        }

        if(i == 0)
        {
            printf("%c\n", symbol);
        }
        else if(i == 4)
        {
            for(int k = 0; k < 9; k++)
            {
                printf("%c ", symbol);
            }
            printf("\n");
        }
        else
        {
            printf("%c", symbol);
            for(int j = 0; j < (i * 4 - 1); j++)
            {
                printf(" ");
            }
            printf("%c\n", symbol);
        }
        spaces -= 2;
    }
    printf("\nObraten triugulnik:\n\n");
    spaces = 0;
    for(int i = 4; i >= 0; i--)
    {
        for(int j = 0; j < spaces; j++)
        {
            printf(" ");
        }

        if(i == 0)
        {
            printf("%c\n", symbol);
        }
        else if(i == 4)
        {
            for(int k = 0; k < 9; k++)
            {
                printf("%c ", symbol);
            }
            printf("\n");
        }
        else
        {
            printf("%c", symbol);
            for(int j = 0; j < (i * 4 - 1); j++)
            {
                printf(" ");
            }
            printf("%c\n", symbol);
        }
        spaces += 2;
    }
    printf("\n");

    return 0;
}

