int zadacha15()
{
    double N, W, L, M, O;
    double plosht_ploshtadka, plosht_peyka, plosht_za_pokrivane;
    double plosht_pochka, broy_pochki;
    double vreme;


    printf("Strana na ploshtadkata N (metri): ");
    scanf("%lf", &N);
    printf("Shirina na plochka W (metri): ");
    scanf("%lf", &W);
    printf("Duljina na plochka L (metri): ");
    scanf("%lf", &L);
    printf("Shirina na peykata M (metri): ");
    scanf("%lf", &M);
    printf("Duljina na peykata O (metri): ");
    scanf("%lf", &O);

    plosht_ploshtadka = N * N;
    plosht_pochka = W * L;
    plosht_peyka = M * O;

    plosht_za_pokrivane = plosht_ploshtadka - plosht_peyka;
    broy_pochki = plosht_za_pokrivane / plosht_pochka;

    vreme = broy_pochki * 0.2;


    printf("Plosht na ploshtadkata: %.2f m2\n", plosht_ploshtadka);
    printf("Plosht na peykata: %.2f m2\n", plosht_peyka);
    printf("Plosht za pokrivane: %.2f m2\n", plosht_za_pokrivane);
    printf("Plosht na edna plochka: %.2f m2\n", plosht_pochka);
    printf("Neobhodimi plochki: %.2f\n", broy_pochki);
    printf("Vreme za postavqne: %.2f minuti\n", vreme);

    return 0;
}
int zadacha16()
{
    double N,M,kurs;
    double bonus, danuci;
    double sredna_pechalba;

    printf("Vuvedete dni, koito raboti sredno: ");
    scanf("%lf",&N);
    printf("Vuvedete pari, koito vadi sredno: ");
    scanf("%lf",&M);
    printf("Vuvedete kurs na dolara (1 USD = ? BGN): ");
    scanf("%lf", &kurs);

    bonus = 2.5*N*M;
    double godina = 12 * N * M + bonus;
    danuci = godina * 0.25;
    sredna_pechalba = (godina - danuci)* kurs / 365;

    printf("Sredna pechalba: %f", sredna_pechalba);
    return 0;
}
