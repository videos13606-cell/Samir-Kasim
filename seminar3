int zadacha_1()
{
    int N;
    printf("vuvedete n broy elementi: ");
    scanf("%d", &N);

    int arr[N];  // Сега N вече е известен
    int start = 0;
    int maxLength = 1;
    int currentStart = 0;
    int currentLength = 1;

    printf("\nvuvedete el na masiva:\n");
    for (int i = 0; i < N; i++)
    {
        printf("arr[%d] = ", i);
        scanf("%d", &arr[i]);
    }

    // Сортиране
    for (int i = 0; i < N - 1; i++)
    {
        for (int j = 0; j < N - i - 1; j++)
        {
            if (arr[j] > arr[j + 1])
            {
                int temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }

    printf("\nSortiran masiv: ");
    for (int i = 0; i < N; i++)
    {
        printf("%d ", arr[i]);
    }
    printf("\n");

    // Намиране на най-дългата площадка
    for (int i = 1; i < N; i++)
    {
        if (arr[i] == arr[i - 1])
        {
            currentLength++;
        }
        else
        {
            if (currentLength > maxLength)
            {
                maxLength = currentLength;
                start = currentStart;
            }
            currentStart = i;
            currentLength = 1;
        }
    }

    if (currentLength > maxLength)
    {
        maxLength = currentLength;
        start = currentStart;
    }

    printf("\nnay dulgata ploshtadka\n");
    printf("nachalo zapochva ot %d element, koyto ima stoynost %d\n", start, arr[start]);
    printf("duljinata na redicata e: %d\n", maxLength);

    return 0;
}

int zadacha_2()
{
    int N;
    printf("vuvedete n broy elementi: ");
    scanf("%d", &N);

    int arr[N];
    bool indicator = true;

    printf("\nvuvedete el na masiva:\n");
    printf("arr[0] = ");
    scanf("%d", &arr[0]);

    for (int i = 1; i < N; i++)
    {
        printf("arr[%d] = ", i);
        scanf("%d", &arr[i]);

        if (i % 2 == 1)
        {
            if (arr[i-1] >= arr[i])
                indicator = false;
        }
        else
        {
            if (arr[i-1] <= arr[i])
                indicator = false;
        }
    }

    if (indicator)
    {
        printf("\nRelaciite sa izpulneni!\n");
    }
    else
    {
        printf("\nRelaciite NE sa izpulneni!\n");
    }

    return 0;
}

int zadacha_3()
{
